# ─────────────────────────────────────────────────────────────────────────────
# apps/web env file hierarchy
# ─────────────────────────────────────────────────────────────────────────────
#
# This file (.env.example)         committed.      Documents required vars. NO SECRETS.
# .env                              gitignored.    Non-secret local defaults.
# .env.local                        gitignored.    **Local secrets go HERE.** Per-machine.
# .env.development.local            gitignored.    Local overrides for `next dev`.
# .env.production.local             gitignored.    Local overrides for `next start`.
# .env.production                   gitignored.    Written by amplify.yml at build time.
#
# Next.js loads them in this priority order (highest first):
#   .env.$NODE_ENV.local > .env.local > .env.$NODE_ENV > .env
# .env.local is NEVER loaded when NODE_ENV=test.
#
# `NEXT_PUBLIC_*` vars are inlined into the client bundle at build time —
# never put a secret behind that prefix.
#
# Production: configure these in Vercel/Amplify env vars, not in files.

# Public URL where this app is served. Used by Next, OpenGraph, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000
