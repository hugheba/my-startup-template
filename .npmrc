engine-strict=true
auto-install-peers=true
package-manager-strict=true
strict-peer-dependencies=false
# AWS Amplify WEB_COMPUTE (Next.js SSR) can't resolve `next` through pnpm's
# default symlinked store at deploy time. A hoisted (flat) node_modules lets
# Amplify and Next's standalone tracer find runtime deps. See FAQ:
# https://github.com/aws-amplify/amplify-hosting/blob/main/FAQ.md#using-a-monorepo-framework
node-linker=hoisted
